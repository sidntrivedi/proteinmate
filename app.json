{
  "expo": {
    "name": "ProteinMate",
    "slug": "proteinmate",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "proteinmate",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.proteinmate.app",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "ProteinMate uses the microphone so you can log meals by voice."
      }
    },
    "android": {
      "package": "com.proteinmate.app",
      "adaptiveIcon": {
        "backgroundColor": "#f7f3ea"
      },
      "permissions": [
        "RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      [
        "expo-audio",
        {
          "microphonePermission": "ProteinMate uses the microphone so you can log meals by voice."
        }
      ]
    ],
    "extra": {
      "sttProxyUrl": "http://192.168.1.5:8787"
    }
  }
}
