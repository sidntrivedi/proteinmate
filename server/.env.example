# Copy to .env and fill in your keys: cp .env.example .env

# --- Stage 1: Speech-to-text ---
# openai (default) or deepgram
STT_PROVIDER=openai

# Required when STT_PROVIDER=openai. Get one at https://platform.openai.com (Settings -> API Keys)
OPENAI_API_KEY=sk-your-openai-key
# Optional override (default: gpt-4o-mini-transcribe)
# OPENAI_STT_MODEL=gpt-4o-mini-transcribe

# Required only when STT_PROVIDER=deepgram
# DEEPGRAM_API_KEY=your-deepgram-key
# DEEPGRAM_MODEL=nova-3

# --- Stage 2: Transcript parsing (Ollama Cloud) ---
# Required for /parse. Create one at https://ollama.com/settings/keys
OLLAMA_API_KEY=your-ollama-cloud-key
# Optional overrides
# OLLAMA_BASE_URL=https://ollama.com/v1
# OLLAMA_PARSE_MODEL=gpt-oss:20b

# --- Server ---
# PORT=8787
